{
  "name": "socketio",
  "version": "1.0.0",

  "scripts": {
  "start": "npm run build && node server/index.js",
  "build": "npm install --prefix client && npm run build --prefix client",
  "dev": "concurrently \"npm run client\" \"npm run server\"",
  "client": "npm run start --prefix client"
},

  "dependencies": {
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.7"
  }
}
